<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
</head>
<body>
  <div class="header">
    <div>
      <h1>FACTURA</h1>
      <p>N° {{numero_factura}}</p>
    </div>
    <div class="info">
      <p><strong>Fecha:</strong> {{fecha}}</p>
      <p><strong>Vencimiento:</strong> {{vencimiento}}</p>
    </div>
  </div>

  <div class="cliente-section">
    <h3>Facturado a</h3>
    <p>{{cliente}}</p>
    <p>{{email_cliente}}</p>
  </div>

  <table>
    <thead>
      <tr>
        <th>Descripción</th>
        <th>Cant.</th>
        <th>Precio Unit.</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td>{{descripcion}}</td>
        <td>{{cantidad}}</td>
        <td>${{precio}}</td>
        <td>${{total}}</td>
      </tr>
      {{/each}}
      <tr class="total-row">
        <td colspan="3">TOTAL</td>
        <td>${{total_general}}</td>
      </tr>
    </tbody>
  </table>

  <div class="footer">
    <p>Generado por DocEngine-X · {{fecha}}</p>
  </div>
</body>
</html>
